# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── LiteLLM ───────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-local-test-key

# ── GitHub MCP ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── Zapier MCP ────────────────────────────────────────────────────────────────
ZAPIER_MCP_URL=https://mcp.zapier.com/api/v1/connect?token=...

# ── PinkFish MCP ──────────────────────────────────────────────────────────────
# OAuth2 client_credentials — LiteLLM fetches/refreshes JWT automatically
PINKFISH_CLIENT_ID=...
PINKFISH_CLIENT_SECRET=...
PINKFISH_ORG_ID=...
# Per-connection IDs from PinkFish dashboard (Connections page)
PINKFISH_SALESFORCE_PCID=...
PINKFISH_EXCEL_PCID=...

# ── Figma MCP (PAT — connects but no tools, OAuth2 PKCE required) ─────────────
FIGMA_TOKEN=figd_...

# ── Database (LiteLLM usage tracking — optional) ──────────────────────────────
DATABASE_URL=postgresql://...
